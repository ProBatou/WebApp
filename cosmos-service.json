{
  "services": {
    "webapp-v2": {
      "container_name": "webapp-v2",
      "image": "ghcr.io/probatou/webapp:latest",
      "environment": [
        "NODE_ENV=production",
        "PORT=3004",
        "DATABASE_PATH=/app/data/webapp.db"
      ],
      "labels": {
        "cosmos-force-network-mode": "bridge"
      },
      "ports": [
        "0.0.0.0:3004:3004/tcp",
        ":::3004:3004/tcp"
      ],
      "volumes": [
        {
          "Type": "volume",
          "Source": "webapp-data",
          "Target": "/app/data"
        }
      ],
      "networks": {
        "bridge": {}
      },
      "routes": null,
      "restart": "unless-stopped",
      "devices": null,
      "expose": [],
      "user": "0:0",
      "runtime": "runc",
      "hostname": "webapp-v2",
      "network_mode": "bridge"
    }
  }
}
