{
  "services": {
    "webapp-v2": {
      "container_name": "webapp-v2",
      "image": "ghcr.io/probatou/webapp:latest",
      "environment": [
        "NODE_ENV=production",
        "PORT=3004",
        "DATABASE_PATH=/app/data/webapp.db"
      ],
      "labels": {
        "cosmos-force-network-mode": "bridge"
      },
      "ports": [
        "0.0.0.0:3004:3004/tcp",
        ":::3004:3004/tcp"
      ],
      "volumes": [
        {
          "Type": "bind",
          "Source": "/cosmos-storage/webapp-v2/data",
          "Target": "/app/data"
        }
      ],
      "networks": {
        "bridge": {}
      },
      "routes": null,
      "restart": "unless-stopped",
      "devices": null,
      "expose": [],
      "runtime": "runc",
      "hostname": "webapp-v2",
      "network_mode": "bridge",
      "healthcheck": {
        "test": [
          "CMD",
          "wget",
          "-qO-",
          "http://localhost:3004/api/health"
        ],
        "interval": 30000000000,
        "timeout": 5000000000,
        "retries": 3,
        "start_period": 60000000000
      }
    }
  }
}
